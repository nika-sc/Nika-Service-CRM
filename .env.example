# NikaNewCrm — Production
# Скопируйте в .env и заполните значения

# Обязательно! Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars

# Режим (production)
FLASK_ENV=production

# Драйвер БД: только postgres (политика проекта)
DB_DRIVER=postgres

# PostgreSQL DSN (если DB_DRIVER=postgres)
# Формат: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://nikacrm:change-me@postgres:5432/nikacrm
# Пул соединений PostgreSQL (ускоряет многократные запросы)
PG_POOL_MINCONN=2
PG_POOL_MAXCONN=20

# Rate limit (memory:// для одного процесса; redis:// для нескольких воркеров)
RATELIMIT_STORAGE_URI=memory://
WRITE_API_RATE_LIMIT_PER_MIN=120

# Host header allowlist (через запятую, без схемы). На сервере укажите свой домен и при необходимости IP.
TRUSTED_HOSTS=localhost,127.0.0.1
# Важно при Docker: переменные выше (TRUSTED_HOSTS, SOCKETIO_*) должны попадать в процесс web.
# В этом репозитории они перечислены в docker/docker-compose.yml → services.web.environment.
# Если клонировали шаблон без этих строк — добавьте их в compose, иначе за nginx будет 400 invalid_host.
# Для systemd/gunicorn достаточно EnvironmentFile=.env (все ключи из .env видны приложению).

# CSP: на проде за HTTPS лучше enforcement (false = enforce)
CSP_REPORT_ONLY=false
# Для точечного enforcement (например только API): /api/,/portal/api/
CSP_ENFORCE_PATH_PREFIXES=
# Опционально URL сборщика CSP-репортов
CSP_REPORT_URI=

# HTTPS: на проде за TLS обязательно true — Secure-cookie сессии
USE_HTTPS=true

# Brute-force lockout (staff login)
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_WINDOW_SEC=600
LOGIN_LOCKOUT_DURATION_SEC=1800

# Brute-force lockout (portal login)
PORTAL_LOGIN_LOCKOUT_THRESHOLD=8
PORTAL_LOGIN_LOCKOUT_WINDOW_SEC=600
PORTAL_LOGIN_LOCKOUT_DURATION_SEC=1800

# Часовой пояс (3 = Москва)
TIMEZONE_OFFSET=3

# Почта (для писем клиентам и директору). На сервере задайте эти переменные, если не настраиваете SMTP в интерфейсе.
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@your-domain.com

# Web Push (чат сотрудников, вкладка может быть закрыта). Опционально.
# Сгенерировать ключи: python scripts/generate_staff_chat_vapid_keys.py
# Или одноразово дописать в .env: python scripts/ensure_staff_chat_vapid_env.py
# STAFF_CHAT_VAPID_PUBLIC_KEY=
# STAFF_CHAT_VAPID_PRIVATE_KEY=   # PEM в одной строке, переводы как \n
# STAFF_CHAT_VAPID_CLAIM_EMAIL=mailto:admin@example.com

# Публичное демо: панель на /login (учётка, живые счётчики из БД, текст про сервер).
# На боевом CRM не включать.
# DEMO_LOGIN_BANNER=1
# DEMO_LOGIN_USERNAME_HINT=demo_admin
# DEMO_LOGIN_PASSWORD_HINT=Demo2026!
# DEMO_SERVER_SPEC=Одна строка или несколько через \n в значении переменной
#
# Реферал VPS (панель демо-входа; по умолчанию FirstVDS)
# REFERRAL_VPS_PROVIDER_LABEL=FirstVDS
# REFERRAL_VPS_URL=https://firstvds.ru/?from=528402
# REFERRAL_VPS_PROMO_CODE=648528402
