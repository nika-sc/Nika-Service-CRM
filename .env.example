# NikaNewCrm — Production
# Скопируйте в .env и заполните значения

# Обязательно! Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars

# Режим (production)
FLASK_ENV=production

# Драйвер БД: postgres (рекомендуется и используется по умолчанию)
DB_DRIVER=postgres

# PostgreSQL DSN (если DB_DRIVER=postgres)
# Формат: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://nikacrm:change-me@postgres:5432/nikacrm
# Пул соединений PostgreSQL (ускоряет многократные запросы)
PG_POOL_MINCONN=2
PG_POOL_MAXCONN=20

# Rate limit (memory:// для одного процесса; redis:// для нескольких воркеров)
RATELIMIT_STORAGE_URI=memory://

# Часовой пояс (3 = Москва)
TIMEZONE_OFFSET=3

# Почта (для писем клиентам и директору). На сервере задайте эти переменные, если не настраиваете SMTP в интерфейсе.
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@your-domain.com

# Web Push (чат сотрудников, вкладка может быть закрыта). Опционально.
# Сгенерировать ключи: python scripts/generate_staff_chat_vapid_keys.py
# Или одноразово дописать в .env: python scripts/ensure_staff_chat_vapid_env.py
# STAFF_CHAT_VAPID_PUBLIC_KEY=
# STAFF_CHAT_VAPID_PRIVATE_KEY=   # PEM в одной строке, переводы как \n
# STAFF_CHAT_VAPID_CLAIM_EMAIL=mailto:admin@example.com
